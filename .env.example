# Optional — enables real Claude vision analysis and AI designer narratives.
# Without it, Maison runs in deterministic demo mode (sample rooms are fully
# functional; uploaded photos get a simulated analysis).
ANTHROPIC_API_KEY=

# Optional — enables the live VidaXL dropship feed at /suppliers. Without
# both set, that page falls back to a realistic mock feed so the ingestion
# pipeline (see lib/suppliers/) is testable before real credentials exist.
VIDAXL_API_KEY=
VIDAXL_API_URL=
