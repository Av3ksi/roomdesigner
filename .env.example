# Optional — enables real Claude vision analysis and AI designer narratives.
# Without it, Maison runs in deterministic demo mode (sample rooms are fully
# functional; uploaded photos get a simulated analysis).
ANTHROPIC_API_KEY=

# Optional — enables the live VidaXL/DropshippingXL dropship feed at
# /suppliers. Without all three set, that page falls back to a realistic
# mock feed so the ingestion pipeline (see lib/suppliers/) is testable
# before real credentials exist.
#
# VIDAXL_API_URL: base URL only, no path — use the sandbox first
# (request access via support@dropXL.com) before pointing at prod:
#   sandbox: https://sandbox.b2b.dropxl.com
#   prod:    https://b2b.dropxl.com
# VIDAXL_ACCOUNT_EMAIL: the email your DropshippingXL account is registered
# with — required alongside the token because their API uses HTTP Basic
# auth (email:token), not a bearer token.
# VIDAXL_API_KEY: the API token generated in your DropshippingXL dashboard.
VIDAXL_API_URL=
VIDAXL_ACCOUNT_EMAIL=
VIDAXL_API_KEY=

# Optional — enables the GPT-Image compositing step (lib/ai/composite.ts):
# inserting a real product photo into a real room photo via a masked edit,
# and (with ANTHROPIC_API_KEY also set) removing furniture already
# physically in a room photo (lib/ai/locate.ts + removeExistingObject —
# no separate provider needed for that). Separate account/billing from
# ANTHROPIC_API_KEY — Claude has no image generation/editing capability,
# this specifically needs OpenAI. Real cost per call (roughly
# $0.01–$0.03/image at low/medium quality with gpt-image-1.5 at time of
# writing — confirm current pricing yourself, this isn't guaranteed to
# stay accurate).
OPENAI_API_KEY=

# Optional — enables Postgres persistence (lib/db.ts): rooms, chat history,
# constraints and rendered versions survive a refresh instead of living only
# in the browser tab. A Neon connection string works as-is (the driver is
# @neondatabase/serverless); any standard Postgres connection string should
# work too. Without this, the Designer Agent still works, just stateless.
# After setting this, run `npx tsx scripts/seed-products.ts` once to load
# the catalog into Postgres (otherwise search falls back to the live feed).
DATABASE_URL=
